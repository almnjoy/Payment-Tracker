{
  "title": "Quick IT Projects - API Reference",
  "version": "1.0.0",
  "baseUrl": "https://portal.quickitprojects.com",
  "authentication": {
    "type": "Replit Auth (OpenID Connect) + JWT Bearer for mobile",
    "notes": "Web app uses session-based auth via cookies. Native mobile apps use JWT Bearer tokens via Authorization header. Admin endpoints require admin role. Client endpoints require client role. Admin impersonation supported via ?asClientId={id} query parameter on client endpoints.",
    "mobile": {
      "flow": "1. Authenticate via browser session, 2. POST /api/mobile/auth/token to mint tokens, 3. Use Authorization: Bearer <accessToken> for all API calls, 4. POST /api/mobile/auth/refresh when access token expires",
      "accessTokenTTL": "15 minutes (configurable via MOBILE_ACCESS_TTL_MINUTES)",
      "refreshTokenTTL": "30 days (configurable via MOBILE_REFRESH_TTL_DAYS)",
      "tokenFormat": "JWT HS256 with aud=mobile, iss=quickitprojects"
    }
  },
  "endpoints": {
    "auth": [
      {
        "method": "GET",
        "path": "/api/me",
        "auth": "authenticated",
        "description": "Get current user profile and role",
        "response": {
          "id": "number",
          "replitId": "string",
          "username": "string",
          "role": "admin | client | null",
          "clientId": "number | null",
          "email": "string | null",
          "profileImage": "string | null"
        }
      },
      {
        "method": "POST",
        "path": "/api/admin/bootstrap",
        "auth": "authenticated",
        "description": "Bootstrap first admin user",
        "body": {
          "secret": "string (SETUP_ADMIN_2024)"
        }
      }
    ],
    "mobileAuth": [
      {
        "method": "POST",
        "path": "/api/mobile/auth/token",
        "auth": "authenticated (cookie session)",
        "description": "Exchange browser session for mobile JWT tokens",
        "body": { "deviceName": "string (optional)" },
        "response": {
          "accessToken": "string (JWT)",
          "refreshToken": "string (opaque)",
          "tokenType": "Bearer",
          "expiresInSeconds": "number"
        }
      },
      {
        "method": "POST",
        "path": "/api/mobile/auth/refresh",
        "auth": "public",
        "description": "Refresh access token using refresh token",
        "body": { "refreshToken": "string" },
        "response": {
          "accessToken": "string (JWT)",
          "tokenType": "Bearer",
          "expiresInSeconds": "number"
        }
      },
      {
        "method": "POST",
        "path": "/api/mobile/auth/logout",
        "auth": "Bearer token or refresh token",
        "description": "Revoke refresh token and/or access token JTI",
        "body": { "refreshToken": "string (optional)" },
        "response": { "ok": "boolean" }
      },
      {
        "method": "GET",
        "path": "/api/mobile/me",
        "auth": "Bearer token",
        "description": "Get user profile via Bearer token (same shape as GET /api/me)",
        "response": {
          "userId": "string",
          "email": "string",
          "firstName": "string | null",
          "lastName": "string | null",
          "profile": "object | null",
          "hasProfile": "boolean"
        }
      }
    ],
    "registration": [
      {
        "method": "POST",
        "path": "/api/invite/verify",
        "auth": "public",
        "description": "Verify an invite code exists and is unused",
        "body": { "code": "string" },
        "response": { "valid": "boolean", "clientName": "string" }
      },
      {
        "method": "POST",
        "path": "/api/invite/claim",
        "auth": "authenticated",
        "description": "Claim invite code to link account to client profile",
        "body": { "code": "string" }
      },
      {
        "method": "POST",
        "path": "/api/client-signup/verify",
        "auth": "public",
        "description": "Verify client signup code",
        "body": { "code": "string" }
      },
      {
        "method": "POST",
        "path": "/api/client-signup/claim",
        "auth": "authenticated",
        "description": "Claim client signup code",
        "body": { "code": "string" }
      }
    ],
    "admin_clients": [
      {
        "method": "GET",
        "path": "/api/admin/clients",
        "auth": "admin",
        "description": "List all clients"
      },
      {
        "method": "GET",
        "path": "/api/admin/clients/:clientId",
        "auth": "admin",
        "description": "Get single client by ID"
      },
      {
        "method": "POST",
        "path": "/api/admin/clients",
        "auth": "admin",
        "description": "Create a new client",
        "body": {
          "name": "string",
          "email": "string",
          "phone": "string (optional)",
          "address": "string (optional)"
        }
      },
      {
        "method": "DELETE",
        "path": "/api/admin/clients/:clientId",
        "auth": "admin",
        "description": "Delete a client"
      },
      {
        "method": "PATCH",
        "path": "/api/admin/clients/:clientId/status",
        "auth": "admin",
        "description": "Update client status",
        "body": { "status": "active | paused | inactive | behind" }
      }
    ],
    "admin_billing_items": [
      {
        "method": "GET",
        "path": "/api/admin/clients/:clientId/billing-items",
        "auth": "admin",
        "description": "Get billing items for a specific client"
      },
      {
        "method": "POST",
        "path": "/api/admin/clients/:clientId/billing-items",
        "auth": "admin",
        "description": "Create a billing item for a client",
        "body": {
          "title": "string",
          "amountCents": "number",
          "frequency": "monthly | weekly | biweekly | yearly | one_time",
          "type": "rent | other",
          "status": "active | inactive"
        }
      },
      {
        "method": "DELETE",
        "path": "/api/admin/clients/:clientId/billing-items/:id",
        "auth": "admin",
        "description": "Delete a billing item"
      },
      {
        "method": "GET",
        "path": "/api/admin/billing-items",
        "auth": "admin",
        "description": "Get all billing items across all clients"
      }
    ],
    "admin_leases": [
      {
        "method": "GET",
        "path": "/api/admin/leases",
        "auth": "admin",
        "description": "List all leases"
      },
      {
        "method": "POST",
