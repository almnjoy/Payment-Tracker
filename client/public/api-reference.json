        "description": "Update invoice"
      },
      {
        "method": "DELETE",
        "path": "/api/admin/invoices/:invoiceId",
        "auth": "admin",
        "description": "Delete invoice"
      },
      {
        "method": "GET",
        "path": "/api/admin/invoices/:invoiceId/pdf",
        "auth": "admin",
        "description": "Download invoice as PDF",
        "response": "application/pdf binary"
      }
